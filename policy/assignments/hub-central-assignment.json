{
  "$schema": "https://schema.management.azure.com/schemas/2019-08-01/managementGroupDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "rootMgName":        { "type": "string", "defaultValue": "mg-saas-platform" },
    "hubMgName":         { "type": "string", "defaultValue": "mg-hub-centralus" },
    "hubRegion":         { "type": "string", "defaultValue": "centralus" },
    "avnmName":          { "type": "string", "defaultValue": "avnm-hub-central" },
    "avnmResourceGroup": { "type": "string", "defaultValue": "rg-avnm-central" },
    "subscriptionId":    { "type": "string" },
    "ngMappings": {
      "type": "array",
      "defaultValue": [
        { "ng": "prod-spokes",    "tagValue": "central-prod-spokes" },
        { "ng": "nonprod-spokes", "tagValue": "central-nonprod-spokes" },
        { "ng": "dr-spokes",      "tagValue": "central-dr-spokes" }
      ]
    }
  },
  "variables": {
    "avnmIdPrefix": "[concat('/subscriptions/', parameters('subscriptionId'), '/resourceGroups/', parameters('avnmResourceGroup'), '/providers/Microsoft.Network/networkManagers/', parameters('avnmName'), '/networkGroups/')]"
  },
  "resources": [
    {
      "copy": { "name": "ngAssignments", "count": "[length(parameters('ngMappings'))]" },
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2023-04-01",
      "name": "[concat('avnm-ng-', parameters('ngMappings')[copyIndex()].ng)]",
      "location": "[parameters('hubRegion')]",
      "properties": {
        "displayName": "[concat('AVNM NG membership: ', parameters('ngMappings')[copyIndex()].ng)]",
        "policyDefinitionId": "[concat('/providers/Microsoft.Management/managementGroups/', parameters('rootMgName'), '/providers/Microsoft.Authorization/policyDefinitions/add-vnet-to-networkgroup')]",
        "scope": "[concat('/providers/Microsoft.Management/managementGroups/', parameters('hubMgName'))]",
        "parameters": {
          "networkGroupId": { "value": "[concat(variables('avnmIdPrefix'), parameters('ngMappings')[copyIndex()].ng)]" },
          "tagKey":         { "value": "avnmGroup" },
          "tagValue":       { "value": "[parameters('ngMappings')[copyIndex()].tagValue]" },
          "requireRegion":  { "value": "[parameters('hubRegion')]" }
        }
      }
    }
  ]
}
