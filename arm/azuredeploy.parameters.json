        { "name": "avnm-hub-central", "location": "centralus", "mgName": "mg-hub-centralus", "subscriptionId": "00000000-0000-0000-0000-000000000000", "resourceGroup": "rg-avnm-central", "addressSpace": "10.50.0.0/12" }
